{
  "name": "@ancientpantheon/pythia",
  "version": "1.13.1",
  "description": "Pythia gateway service — the private Hono runtime that serves the pooled, failover-safe read API. Deployed, never published.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ancientpantheon/codex": "^0.6.0",
    "@hono/node-server": "^2.0.0",
    "@noble/hashes": "^1.8.0",
    "@stoachain/dalos-crypto": "^4.0.3",
    "@stoachain/kadena-stoic-legacy": "^4.3.6",
    "@stoachain/stoa-core": "^4.3.6",
    "hono": "^4.12.0",
    "jose": "^5.9.6",
    "libsodium-wrappers": "^0.8.4"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14"
  }
}
