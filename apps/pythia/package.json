{
  "name": "@ancientpantheon/pythia",
  "version": "1.13.1",
  "description": "Pythia gateway service — the private Hono runtime that serves the pooled, failover-safe read API. Deployed, never published.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-codex-island.mjs",
    "build:island": "node scripts/build-codex-island.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ancientpantheon/codex": "^0.6.0",
    "@hono/node-server": "^2.0.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@stoachain/dalos-crypto": "^4.0.3",
    "@stoachain/kadena-stoic-legacy": "^4.3.6",
    "@stoachain/stoa-core": "^4.3.6",
    "buffer": "^6.0.3",
    "hono": "^4.12.0",
    "jose": "^5.9.6",
    "libsodium-wrappers": "^0.8.4",
    "lucide-react": "^1.25.0"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
